PORT=4185
APP_BASE_URL=http://127.0.0.1:4185
APP_ENCRYPTION_KEY=replace_with_a_long_random_value

# SMTP settings for automatic invite emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=security@example.com
SMTP_PASS=replace_me
MAIL_FROM="Keynius Security Training <security@example.com>"

# Optional Microsoft 365 OAuth defaults.
# These can also be entered and updated from the admin dashboard and are stored encrypted in SQLite.
# Create an Entra ID app registration and allow delegated permissions:
# Mail.Send, User.Read, openid, profile, email, offline_access
MS_TENANT_ID=organizations
MS_CLIENT_ID=replace_with_app_client_id
# Optional when your app uses PKCE without a confidential client secret
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://127.0.0.1:4185/auth/microsoft/callback
